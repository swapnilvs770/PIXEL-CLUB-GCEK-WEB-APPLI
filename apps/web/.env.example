# PCMP Frontend environment variables
# Copy to .env (Vite reads any VITE_* prefixed variable at build/dev time).

# Backend API base URL (used by axios client). Trailing /api is required.
VITE_API_BASE_URL=http://localhost:5000/api

# Socket.IO server URL (no trailing /api)
VITE_SOCKET_URL=http://localhost:5000

# Display name (overrides the default in <title> and headers)
VITE_APP_NAME="Pixel Club Management Portal"

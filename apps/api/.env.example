# PCMP Backend environment variables
# Copy to .env and fill in real values. Never commit the real .env file.

NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
CLIENT_BASE_URL=http://localhost:5173

# MongoDB Atlas connection string
MONGO_URI=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI must match: ${API_BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Comma-separated emails that should be promoted to Admin on first OAuth login
ADMIN_BOOTSTRAP_EMAILS=

# JWT (used after Google OAuth to issue session tokens for the SPA)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Drive API
# Recommended: create a Service Account in Google Cloud, share source folders
# with that service account's email, and paste the entire JSON (one line) below.
GOOGLE_SERVICE_ACCOUNT_JSON=

# SMTP (Gmail app password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Pixel Club <noreply@pixelclub.in>"

LOG_LEVEL=info

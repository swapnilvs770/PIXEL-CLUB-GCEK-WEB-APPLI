node_modules/
.pnp
.pnp.js

# ─────────────────────────────────────────────────────────────
# Build outputs
# ─────────────────────────────────────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────

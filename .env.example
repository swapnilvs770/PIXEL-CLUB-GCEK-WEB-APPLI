# =============================================================
# PCMP - Root .env.example
# Copy this file to .env and fill in real values for local dev.
# The actual envs the apps read live in:
#   apps/api/.env   -> loaded by the backend
#   apps/web/.env   -> loaded by Vite (must be prefixed VITE_)
#
# This root file is a TEMPLATE / documentation only.
# =============================================================

# --- Backend (apps/api/.env) ---
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
CLIENT_BASE_URL=http://localhost:5173

MONGO_URI=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# Optional: comma-separated list of admin emails bootstrapped on first run
ADMIN_BOOTSTRAP_EMAILS=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Drive API (Service Account recommended for server-side folder reads)
# Create a service account, share the source folders with its email, and paste the JSON (one line) below.
GOOGLE_SERVICE_ACCOUNT_JSON=

# SMTP / Nodemailer (Gmail app password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Pixel Club <noreply@pixelclub.in>"

# Logging
LOG_LEVEL=info

# --- Frontend (apps/web/.env) ---
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_APP_NAME="Pixel Club Management Portal"
